<Window x:Class="AirportSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AirportSimulator"
        mc:Ignorable="d"
        Title="MainWindow" Height="526" Width="800">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Input form -->
        <StackPanel Grid.Column="0" Margin="10">

            <TextBlock Text="Flight Name"/>
            <TextBox x:Name="NameBox"/>

            <TextBlock Text="Flight Number"/>
            <TextBox x:Name="FlightNumberBox"/>

            <TextBlock Text="Destination"/>
            <TextBox x:Name="DestinationBox"/>

            <TextBlock Text="Flight Time (hours)"/>
            <TextBox x:Name="TimeBox"/>

            <Button Content="Add Plane"
                Margin="10"
                Click="AddAirplane_Click"/>

            <Button Content="Take Off"
                Margin="10"
                Click="TakeOff_Click"/>
        </StackPanel>

        <!-- RIGHT: Planes + Log -->
        <StackPanel Grid.Column="1" Margin="10">

            <TextBlock Text="Flights" FontWeight="Bold"/>
            <ListBox x:Name="AirplaneList" Height="150"/>

            <Button Content="Change Altitude"
                Margin="5"
                Click="Altitude_Click"/>

            <Button Content="Remove"
                Margin="5"
                Click="Remove_Click"/>

            <TextBlock Text="Log" FontWeight="Bold"/>
            <ListBox x:Name="LogList" Height="200"/>
        </StackPanel>
    </Grid>

</Window>
